{
  "info": {
    "name": "brXM Marketplace API",
    "description": "API collection for testing the Bloomreach Forge Marketplace endpoints (Essentials)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "admin",
        "type": "string"
      },
      {
        "key": "password",
        "value": "admin",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/essentials/rest/dynamic/marketplace"
    }
  ],
  "item": [
    {
      "name": "List Addons",
      "item": [
        {
          "name": "List All Addons",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons"
            },
            "description": "Returns all registered addons"
          }
        },
        {
          "name": "Filter by Category - Security",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=security",
              "query": [
                {
                  "key": "category",
                  "value": "security"
                }
              ]
            },
            "description": "Filter addons by category. Valid values: content-management, developer-tools, integration, search, personalization, analytics, security, media, workflow, seo, other"
          }
        },
        {
          "name": "Filter by Category - Integration",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=integration",
              "query": [
                {
                  "key": "category",
                  "value": "integration"
                }
              ]
            }
          }
        },
        {
          "name": "Filter by Category - SEO",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=seo",
              "query": [
                {
                  "key": "category",
                  "value": "seo"
                }
              ]
            }
          }
        },
        {
          "name": "Filter by Category - Developer Tools",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=developer-tools",
              "query": [
                {
                  "key": "category",
                  "value": "developer-tools"
                }
              ]
            }
          }
        },
        {
          "name": "Filter by Category - Content Management",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=content-management",
              "query": [
                {
                  "key": "category",
                  "value": "content-management"
                }
              ]
            }
          }
        },
        {
          "name": "Filter by Category - Media",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=media",
              "query": [
                {
                  "key": "category",
                  "value": "media"
                }
              ]
            }
          }
        },
        {
          "name": "Filter by Category - Workflow",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=workflow",
              "query": [
                {
                  "key": "category",
                  "value": "workflow"
                }
              ]
            }
          }
        },
        {
          "name": "Filter by brXM Version - 16.0.0",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?brxmVersion=16.0.0",
              "query": [
                {
                  "key": "brxmVersion",
                  "value": "16.0.0"
                }
              ]
            },
            "description": "Filter addons compatible with specified brXM version"
          }
        },
        {
          "name": "Filter by brXM Version - 15.0.0",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?brxmVersion=15.0.0",
              "query": [
                {
                  "key": "brxmVersion",
                  "value": "15.0.0"
                }
              ]
            }
          }
        },
        {
          "name": "Combined Filters - Category + Version",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=security&brxmVersion=16.0.0",
              "query": [
                {
                  "key": "category",
                  "value": "security"
                },
                {
                  "key": "brxmVersion",
                  "value": "16.0.0"
                }
              ]
            },
            "description": "Multiple filters can be combined - all conditions must match"
          }
        },
        {
          "name": "Invalid Filter - Returns Empty",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons?category=invalid-category",
              "query": [
                {
                  "key": "category",
                  "value": "invalid-category"
                }
              ]
            },
            "description": "Invalid filter values return empty array (not an error)"
          }
        }
      ]
    },
    {
      "name": "Search Addons",
      "item": [
        {
          "name": "Search by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/search?q=filter",
              "query": [
                {
                  "key": "q",
                  "value": "filter"
                }
              ]
            },
            "description": "Search addons by name or description (case-insensitive)"
          }
        },
        {
          "name": "Search by Description",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/search?q=security",
              "query": [
                {
                  "key": "q",
                  "value": "security"
                }
              ]
            },
            "description": "Search matches against addon descriptions too"
          }
        },
        {
          "name": "Search - Empty Query",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/search?q=",
              "query": [
                {
                  "key": "q",
                  "value": ""
                }
              ]
            },
            "description": "Empty query returns empty array"
          }
        },
        {
          "name": "Search - No Match",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/search?q=nonexistent",
              "query": [
                {
                  "key": "q",
                  "value": "nonexistent"
                }
              ]
            },
            "description": "Returns empty array when no addons match"
          }
        }
      ]
    },
    {
      "name": "Get Addon by ID",
      "item": [
