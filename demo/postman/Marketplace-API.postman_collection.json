            },
            "description": "Returns 404 with {code: \"ADDON_NOT_FOUND\", message: \"...\"}"
          }
        }
      ]
    },
    {
      "name": "Project Context",
      "item": [
        {
          "name": "Get Project Context",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/project-context"
            },
            "description": "Returns the current project context: brxmVersion, javaVersion, installedAddons (map of addonId \u2192 version), and misconfiguredAddons (map of addonId \u2192 list of PlacementIssue). misconfiguredAddons is omitted when empty."
          }
        },
        {
          "name": "Refresh Project Context",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/project-context/refresh"
            },
            "description": "Invalidates the cached project context and re-reads all POM files. Use after manual POM edits outside the Marketplace UI."
          }
        }
      ]
    },
    {
      "name": "Addon Operations",
      "item": [
        {
          "name": "Install Addon",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/ip-filter/install?upgrade=false",
              "query": [
                {
                  "key": "upgrade",
                  "value": "false"
                }
              ]
            },
            "description": "Installs an addon by adding its Maven artifacts to the appropriate POM files. upgrade=false for fresh install, upgrade=true to update an already-installed addon. Returns InstallationResult with success flag and list of changes."
          }
        },
        {
          "name": "Upgrade Addon",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/ip-filter/install?upgrade=true",
              "query": [
                {
                  "key": "upgrade",
                  "value": "true"
                }
              ]
            },
            "description": "Upgrades an already-installed addon to the latest compatible version. Use upgrade=true to update version properties and dependency coordinates."
          }
        },
        {
          "name": "Uninstall Addon",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/ip-filter/uninstall"
            },
            "description": "Removes the addon's Maven artifacts from all POM files. Returns InstallationResult; warnings are included if some artifacts could not be removed."
          }
        },
        {
          "name": "Fix Addon Misconfiguration",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/addons/ip-filter/fix"
            },
            "description": "Corrects detected PlacementIssues for an addon: moves dependencies to the correct POM, fixes incorrect scopes, and removes duplicates. Use after GET /project-context reveals entries in misconfiguredAddons."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Refresh Manifest",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/refresh"
            },
            "description": "Trigger a refresh of the addon manifest from all configured sources"
          }
        }
      ]
    },
    {
      "name": "Source Management",
      "item": [
        {
          "name": "List Sources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sources"
            },
            "description": "Returns all configured addon sources. Each source has: name, url, enabled, priority, readonly (built-in sources are readonly and cannot be deleted)."
          }
        },
        {
          "name": "Create Source",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"my-partner-registry\",\n  \"url\": \"https://example.com/addons-index.json\",\n  \"enabled\": true,\n  \"priority\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sources"
            },
            "description": "Creates a new addon source. priority controls load order (lower = higher priority). Returns 201 on success, 409 if a source with that name already exists, 400 on validation error."
          }
        },
        {
          "name": "Delete Source",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sources/my-partner-registry"
            },
            "description": "Deletes a source by name. Returns 204 on success, 404 if not found, 403 if the source is readonly (built-in)."
          }
        },
        {
          "name": "Refresh Source",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sources/my-partner-registry/refresh"
            },
            "description": "Forces a re-fetch of addons from the named source. Returns 200 with updated SourceResponse, 404 if not found."
          }
        }
      ]
    }
  ]
}
